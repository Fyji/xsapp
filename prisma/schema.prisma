generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  team_lead
  admin
}

enum ProjectStatus {
  active
  on_hold
  completed
  archived
}

enum Urgency {
  urgent_important
  urgent_not_important
  not_urgent_important
  not_urgent_not_important
}

enum EventType {
  final_submission
  interim_submission
  internal_meeting
  external_meeting
}

enum AvailabilityStatus {
  available
  busy
  unavailable
  not_working
  offsite
}

enum TaskStatus {
  open
  assigned
  in_progress
  done
}

enum HandRaiseType {
  hand
  call
}

enum HandRaiseStatus {
  pending
  done
  later
  dismissed
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(employee)
  title        String?
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  ledProjects      Project[]        @relation("TeamLead")
  projectMembers   ProjectMember[]
  assignedTasks    Task[]           @relation("AssignedTo")
  createdTasks     Task[]           @relation("CreatedBy")
  availability     Availability[]
  handRaisesSent   HandRaise[]      @relation("FromUser")
  handRaisesReceived HandRaise[]    @relation("ToUser")

  @@map("users")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  clientName  String?       @map("client_name")
  description String?
  status      ProjectStatus @default(active)
  urgency     Urgency       @default(not_urgent_not_important)
  teamLeadId  String        @map("team_lead_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  teamLead    User            @relation("TeamLead", fields: [teamLeadId], references: [id])
  members     ProjectMember[]
  events      ProjectEvent[]
  tasks       Task[]

  @@map("projects")
}

model ProjectMember {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  projectId     String   @map("project_id")
  roleInProject String?  @map("role_in_project")
  joinedAt      DateTime @default(now()) @map("joined_at")

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

model ProjectEvent {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  title     String
  type      EventType
  date      DateTime
  time      String?
  notes     String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_events")
}

model Task {
  id             String     @id @default(uuid())
  projectId      String     @map("project_id")
  title          String
  description    String?
  requiredSkills String[]   @map("required_skills")
  urgency        Urgency    @default(not_urgent_not_important)
  deadline       DateTime?
  assignedToId   String?    @map("assigned_to_id")
  status         TaskStatus @default(open)
  createdById    String     @map("created_by_id")
  createdAt      DateTime   @default(now()) @map("created_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User    @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("tasks")
}

model Availability {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  date      DateTime           @db.Date
  status    AvailabilityStatus @default(available)
  dailyNote String?            @map("daily_note")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("availability")
}

model HandRaise {
  id         String          @id @default(uuid())
  fromUserId String          @map("from_user_id")
  toUserId   String          @map("to_user_id")
  type       HandRaiseType
  status     HandRaiseStatus @default(pending)
  createdAt  DateTime        @default(now()) @map("created_at")
  resolvedAt DateTime?       @map("resolved_at")

  fromUser User @relation("FromUser", fields: [fromUserId], references: [id])
  toUser   User @relation("ToUser", fields: [toUserId], references: [id])

  @@map("hand_raises")
}
